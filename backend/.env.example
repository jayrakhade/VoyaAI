# ── Flask Configuration ───────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# ── CORS Configuration ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Gemini API ────────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voyaai
