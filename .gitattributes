# Normalize line endings: LF in repo, platform-native on checkout
* text=auto

# Force LF for these file types regardless of platform
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env*  text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.svg   binary
*.ico   binary
*.pptx  binary
*.zip   binary
